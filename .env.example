# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/bookundo

# Break-glass super-admin credentials (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_DISPLAY_NAME=Super Admin

# Session cookie signing secret — use a long random string in production
ADMIN_SECRET=change-this-to-a-long-random-string

# Public app URL for links in emails and notifications
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: separate API base URL if the frontend calls an external API
# NEXT_PUBLIC_API_URL=

# Set to "false" to require admin approval for new book listings (default: auto-approve)
# AUTO_APPROVE_BOOKS=true

# Email provider for production notifications (logs to console when unset)
# EMAIL_PROVIDER=
